{
  "name": "lsofi",
  "version": "2.0.0",
  "type": "module",
  "description": "Find processes occupying a given port",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "default": "./dist/index.js"
      },
      "require": {
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "check-port": "node src/check-port.ts",
    "lint": "oxlint .",
    "build": "tsdown",
    "test": "npm run lint && node --test src/index.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "tool",
    "cli",
    "ports",
    "lsof",
    "netstat"
  ],
  "author": "Mario Nebl <hello@mario-nebl.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "http://github.com/marionebl/lsofi.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "get-port": "7.1.0",
    "oxlint": "1.55.0",
    "rolldown": "1.0.0-rc.9",
    "tsdown": "0.14.2",
    "typescript": "5.9.3"
  },
  "dependencies": {},
  "optionalDependencies": {
    "@oxlint/binding-darwin-arm64": "1.55.0",
    "@oxlint/binding-darwin-x64": "1.55.0",
    "@oxlint/binding-linux-x64-gnu": "1.55.0",
    "@oxlint/binding-win32-x64-msvc": "1.55.0",
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.9",
    "@rolldown/binding-darwin-x64": "1.0.0-rc.9",
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.9",
    "@rolldown/binding-win32-x64-msvc": "1.0.0-rc.9"
  }
}
